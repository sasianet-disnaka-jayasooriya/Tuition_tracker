rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each family's data is stored under their user UID
    // Only the authenticated user with that UID can read/write their data
    // Since the whole family shares ONE login, all phones access the same document
    match /families/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
